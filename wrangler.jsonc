{
  "name": "my-agent",
  "main": "src/server.ts",
  // Set this to today's date
  "compatibility_date": "2026-03-25",
  "compatibility_flags": ["nodejs_compat"],
  "ai": { "binding": "AI" },
  "durable_objects": {
    "bindings": [
      {
        "name": "CounterAgent",
        "class_name": "CounterAgent"
      },
      {
        "name": "ChatAgent",
        "class_name": "ChatAgent"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["CounterAgent"]
    },
    {
      "tag": "v2",
      "new_sqlite_classes": ["ChatAgent"]
    }
  ]
}
